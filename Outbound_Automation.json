    {
      "parameters": {
        "jsCode": "// --- SAFE NODE ACCESS ---\nconst templateNode = $('Parse Templates (Regex)').first();\nconst templates = templateNode?.json?.templates || {};\n\nconst driveNode = $('Download Resume1').first();\nconst resumeBinary = driveNode?.binary?.data?.data ? driveNode.binary : null;\nconst hasResume = !!resumeBinary;\n\n// --- CONFIG ---\nconst MAX_EMAILS = 75;\nlet emailsScheduled = 0;\n\nconst processedItems = [];\n\n// --- PROCESS LOOP ---\nfor (const item of $input.all()) {\n    const row = { ...item.json };\n    row.row_number = Number(row.row_number);\n\n    const status = row.Status || 'NEW';\n    const replied = String(row.Replied).toUpperCase() === 'TRUE';\n\n    let followUpCount = Number(row['FollowUp Count']);\n    if (isNaN(followUpCount)) followUpCount = 0;\n\n    let lastEmailSent = new Date(row['Last Email Sent']);\n    if (isNaN(lastEmailSent)) lastEmailSent = new Date(0);\n\n    const now = new Date();\n\n    let action = 'SKIP';\n    let emailType = '';\n    let newStatus = status;\n    let errorMsg = '';\n\n   // --- STOP CONDITIONS ---\nif (replied || status === 'NOT_RESPONDED') {\n    row.action = 'SKIP';\n    row.newStatus = status;\n    row.errorMsg = '';\n    processedItems.push({ json: row });\n    continue;\n}\n\n    // --- DETERMINE EMAIL TYPE ---\n    if (status === 'NEW') {\n        action = 'SEND';\n        emailType = 'PRIMARY';\n        newStatus = 'CONTACTED';\n    } else {\n        const diffDays = Math.floor((now - lastEmailSent) / (1000 * 60 * 60 * 24));\n\n        if (!isNaN(diffDays) && diffDays >= 2) {\n            if (followUpCount < 3) {\n                action = 'SEND';\n                emailType = `FOLLOWUP_${followUpCount + 1}`;\n                newStatus = `FOLLOWUP_${followUpCount + 1}`;\n            } else {\n                action = 'UPDATE_ONLY';\n                newStatus = 'NOT_RESPONDED';\n            }\n        }\n    }\n\n    // --- VALIDATION & LIMITS ---\n    if (action === 'SEND') {\n\n        if (emailsScheduled >= MAX_EMAILS) {\n            action = 'DEFERRED';\n            errorMsg = 'Daily email limit reached';\n        }\n\n        else if (!hasResume) {\n            action = 'ERROR';\n            errorMsg = 'Resume attachment missing from Drive.';\n        }\n\n        else if (!templates[emailType] || !Array.isArray(templates[emailType]) || templates[emailType].length === 0) {\n            action = 'ERROR';\n            errorMsg = `Missing template variation for ${emailType}.`;\n        }\n\n        else {\n            const variations = templates[emailType];\n            const selected = variations[Math.floor(Math.random() * variations.length)];\n\n            // --- SAFE VARIABLE REPLACEMENT ---\n            const replaceVars = (str = '') =>\n                str\n                    .replace(/{{Name}}/gi, row.Name || '')\n                    .replace(/{{Company}}/gi, row.Company || '')\n                    .replace(/{{Role}}/gi, row.Role || '');\n\n            row.subjectOut = replaceVars(selected?.subject);\n            row.bodyOut = replaceVars(selected?.body);\n\n            row.newFollowUpCount =\n                emailType.startsWith('FOLLOWUP') ? followUpCount + 1 : followUpCount;\n\n            row.dateStr = now.toISOString();\n\n            emailsScheduled++;\n        }\n    }\n\n    // --- FINAL OUTPUT PREPARATION ---\n    row.action = action;\n    row.newStatus = newStatus;\n    row.errorMsg = errorMsg;\n\n    let outItem = { json: row };\n\n    // --- CORRECT BINARY STRUCTURE ---\n    if (resumeBinary && action === 'SEND') {\n        outItem.binary = resumeBinary;\n    }\n\n    processedItems.push(outItem);\n}\n\n// --- RETURN ---\nreturn processedItems;"
      },
