      },
      "name": "Get Templates1",
      "type": "n8n-nodes-base.googleDocs",
      "typeVersion": 2,
      "position": [
        240,
        32
      ],
      "id": "67d05336-5948-404d-99d2-0527312c87df",
      "alwaysOutputData": false,
      "credentials": {
        "googleDocsOAuth2Api": {
          "id": "zNu1I2mX7yq9ilJG",
          "name": "Google Docs OAuth2 API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// --- INPUT ---\n\nconst text = $input.first()?.json?.content || '';\n\n// --- STORAGE ---\nconst templates = {};\nconst errors = [];\nconst parsedBlocks = {};\n\n// --- REGEX: Extract all === BLOCK === sections ---\nconst regex = /===\\s*([A-Z0-9_]+)\\s*===\\s*([\\s\\S]*?)(?====\\s*[A-Z0-9_]+\\s*===|$)/g;\nlet match;\n\n// Extract all blocks safely\nwhile ((match = regex.exec(text)) !== null) {\n    const key = match[1].trim();\n    const value = match[2].trim();\n    parsedBlocks[key] = value;\n}\n\n// --- PROCESS BLOCKS ---\nfor (const key in parsedBlocks) {\n\n    // Skip subject blocks (we process bodies only)\n    if (key.startsWith('SUBJECT_')) continue;\n\n    const body = parsedBlocks[key];\n    const subjectKey = `SUBJECT_${key}`;\n    const subject = parsedBlocks[subjectKey];\n\n    // --- VALIDATION ---\n    if (!subject) {\n        errors.push(`Missing subject for ${key}`);\n        continue;\n    }\n\n    if (!body) {\n        errors.push(`Missing body for ${key}`);\n        continue;\n    }\n\n    // --- DETERMINE TEMPLATE GROUP ---\n    let group = null;\n\n    if (key.startsWith('PRIMARY')) {\n        group = 'PRIMARY';\n    } \n    else if (key.startsWith('FOLLOWUP_')) {\n        const matchFollow = key.match(/^FOLLOWUP_(\\d+)/);\n        if (matchFollow) {\n            group = `FOLLOWUP_${matchFollow[1]}`;\n        }\n    }\n\n    if (!group) {\n        errors.push(`Unknown template type: ${key}`);\n        continue;\n    }\n\n    // Initialize group if not exists\n    if (!templates[group]) {\n        templates[group] = [];\n    }\n\n    // Add variation\n    templates[group].push({\n        subject,\n        body\n    });\n}\n\n// --- FINAL SAFETY CHECKS ---\nif (!templates.PRIMARY || templates.PRIMARY.length === 0) {\n    errors.push('No PRIMARY templates found');\n}\n\n// Ensure all follow-up levels exist (optional but useful)\nfor (let i = 1; i <= 3; i++) {\n    if (!templates[`FOLLOWUP_${i}`]) {\n        templates[`FOLLOWUP_${i}`] = [];\n    }\n}\n\n// --- OUTPUT ---\nreturn {\n    json: {\n        templates,\n        errors,\n        stats: {\n            totalBlocks: Object.keys(parsedBlocks).length,\n            templateGroups: Object.keys(templates),\n            totalTemplates: Object.values(templates).reduce((sum, arr) => sum + arr.length, 0)\n        }\n    }\n};"
      },
      "name": "Parse Templates (Regex)",
